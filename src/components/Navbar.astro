---
import ThemeToggle from './ThemeToggle.jsx';

const links = [
  { href: '#home', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 flex items-center justify-between px-6 md:px-10 py-4 bg-surface/80 dark:bg-surfaceDark/80 backdrop-blur-xl border-b border-borderLight dark:border-borderDark">
  <a href="#home" class="text-[17px] font-bold tracking-tight">
    Sugumaran<span class="text-inkMuted dark:text-white/50 font-semibold"> S</span>
  </a>

  <ul class="hidden md:flex items-center gap-8 list-none">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="text-sm text-inkMuted dark:text-white/70 hover:text-ink dark:hover:text-white transition-colors"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="flex items-center gap-3">
    <ThemeToggle client:load />
  </div>
</nav>
